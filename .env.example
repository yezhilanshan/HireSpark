# Flask Backend Configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True
FLASK_SECRET_KEY=interview-anti-cheating-secret

# Socket.IO Configuration
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
# Server-side auth proxy target for Next.js API routes
BACKEND_ORIGIN=http://127.0.0.1:5000
NEXT_PUBLIC_ASR_DEBUG_PANEL=true
TTS_SERVICE_URL=http://localhost:5001
TTS_MODE=remote
TTS_ENABLED=true
TTS_TIMEOUT=60

# Auth / Demo account
AUTH_LOGIN_EMAIL=admin@zhiyuexingchen.cn
AUTH_LOGIN_PASSWORD=职跃星辰123
AUTH_LOGIN_NAME=职跃星辰 管理员

# Standalone TTS Service
TTS_PROVIDER=auto
TTS_PROVIDER_ORDER=cosyvoice,edgetts
# 设为 true 时，仅使用首选 provider（auto/edge 下为 edge，melo 下为 melo），不会触发回退
# TTS_PROVIDER_STRICT=true
TTS_SERVICE_PORT=5001
TTS_COSYVOICE_MODEL=cosyvoice-v3-flash
TTS_COSYVOICE_VOICE=Chinese_dramatic_storyteller_vv1
# TTS_MODEL=cosyvoice-v3-flash
# TTS_VOICE=Chinese_dramatic_storyteller_vv1
# TTS_CONDA_ENV=interview-tts
# TTS_MELO_LANGUAGE=ZH
# TTS_MELO_SPEAKER=ZH
# TTS_MELO_DEVICE=auto
# TTS_MELO_SPEED=1.0

# DashScope / Bailian
DASHSCOPE_API_KEY=
BAILIAN_API_KEY=

# LLM Configuration (面试评估)
LLM_PROVIDER=qwen
LLM_MODEL=qwen-max

# Global Assistant (OpenRouter / StepFun)
ASSISTANT_ENABLED=true
ASSISTANT_PROVIDER=openrouter
ASSISTANT_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_API_KEY=
ASSISTANT_FORCE_PLAIN_TEXT=true
ASSISTANT_ASYNC_ENABLED=true
ASSISTANT_TASK_MAX_WORKERS=2
ASSISTANT_TASK_RETENTION_SECONDS=900
ASSISTANT_FAST_ACK_TEXT=已接收，正在分析你的问题...
# 可选：用于 OpenRouter 控制台来源标识
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=tianshuzhimian

# Optional fallback: Ollama
# ASSISTANT_PROVIDER=ollama
# ASSISTANT_MODEL=gemma4:e4b
# ASSISTANT_OLLAMA_BASE_URL=http://127.0.0.1:11434
# ASSISTANT_OLLAMA_THINK=false
# ASSISTANT_OLLAMA_KEEP_ALIVE=2m
# ASSISTANT_OLLAMA_NUM_GPU=0

# Embedding Model (向量嵌入)
EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# Resume Parser Model
RESUME_PARSER_MODEL=qwen3-vl-flash

# Replay Review Model
REPLAY_LLM_MODEL=gemma-4-27b-it

# ASR models
ASR_MODEL=fun-asr-realtime
ASR_FINAL_MODEL=qwen3-asr-flash
ASR_FINAL_MODEL_FALLBACK=qwen3-asr-flash
# 支持填写 DashScope 模型名，或本地目录（例：.\Qwen3-ForcedAligner-0.6B）
ASR_ALIGNER_MODEL=.\Qwen3-ForcedAligner-0.6B
ASR_ALIGNER_ENABLED=true
ASR_ALIGNER_TIMEOUT=90
# auto/cuda:0/cpu
ASR_ALIGNER_LOCAL_DEVICE_MAP=auto
# auto/bfloat16/float16/float32
ASR_ALIGNER_LOCAL_DTYPE=auto
# 留空表示让模型自动判断混合语言；纯中文可填 zh
ASR_FINAL_LANGUAGE=
ASR_FINAL_ENABLE_ITN=true
ASR_FINAL_TIMEOUT=60
# 使用模型原生能力优先，关闭提示词强引导（避免把错误草稿“喂回去”）
ASR_FINAL_USE_HINT_PROMPT=false
# 分段提交时优先使用服务端 sentence-final，减少 partial 抖动污染
ASR_SEGMENT_PREFER_FINAL_ONLY=true
# 流式原生选项：去除口头语 + 原生时间戳对齐
ASR_STREAM_DISFLUENCY_REMOVAL_ENABLED=true
ASR_STREAM_TIMESTAMP_ALIGNMENT_ENABLED=true
# 面试页实时 ASR 诊断事件流（socket: asr_debug）
ASR_DEBUG_STREAM_ENABLED=true
# 中国内地默认可不填；国际站可改为 https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_BASE_HTTP_API_URL=

# ASR runtime / segmentation tuning (optional)
# live_asr.py 读取后端地址，默认 http://localhost:5000
BACKEND_URL=http://localhost:5000
ASR_FINAL_BASE_HTTP_API_URL=
ASR_STREAM_VAD_ENABLED=true
ASR_MIN_SEGMENT_UNITS=3
ASR_PENDING_AUDIO_MAX_CHUNKS=160
ASR_PENDING_AUDIO_MAX_BYTES=2097152

# Live ASR local Edge TTS voice options (optional)
EDGE_TTS_VOICE=
EDGE_TTS_FEMALE_VOICE=zh-CN-XiaoxiaoNeural
EDGE_TTS_MALE_VOICE=zh-CN-YunyangNeural
EDGE_TTS_AUTO_GENDER=true
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_TIMEOUT_SEC=8

# Standalone TTS provider advanced options (optional)
TTS_PROVIDER_STRICT=false
TTS_COSYVOICE_TIMEOUT=45
TTS_COSYVOICE_RETRIES=2
TTS_COSYVOICE_POOL_SIZE=3
TTS_COSYVOICE_FORMAT=MP3_22050HZ_MONO_256KBPS
TTS_COSYVOICE_MEDIA_TYPE=audio/mpeg
TTS_EDGE_VOICE=
TTS_EDGE_FEMALE_VOICE=zh-CN-XiaoxiaoNeural
TTS_EDGE_MALE_VOICE=zh-CN-YunyangNeural
TTS_EDGE_AUTO_GENDER=true
TTS_EDGE_RANDOM_BY_INTERVIEW=true
TTS_EDGE_RATE=+0%
TTS_EDGE_VOLUME=+0%
TTS_EDGE_TIMEOUT=30

# Assistant advanced options (optional)
ASSISTANT_DASHSCOPE_API_KEY=
ASSISTANT_BAILIAN_API_KEY=
ASSISTANT_OPENROUTER_API_KEY=
ASSISTANT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ASSISTANT_QWEN_TEXT_MODEL=qwen-plus
ASSISTANT_MIN_TOKENS=256
ASSISTANT_MAX_TOKENS=2048
ASSISTANT_ADAPTIVE_BASE_TOKENS=640
ASSISTANT_CONTINUATION_MAX_TOKENS=2048
ASSISTANT_STREAM_CHUNK_CHARS=80
ASSISTANT_STREAM_CHUNK_DELAY_MS=15
ASSISTANT_HISTORY_COMPRESS_KEEP_TURNS=6
ASSISTANT_HISTORY_COMPRESS_MAX_CHARS=1800

# Assistant/OpenRouter alias keys (optional)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=tianshuzhimian
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Auth / cookie / security
AUTH_COOKIE_SECURE=false
AUTH_PASSWORD_PBKDF2_ITERATIONS=120000

# Frontend-backend integration overrides (optional)
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
BACKEND_API_BASE=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_SITE_URL=http://localhost:3000
VERCEL_BACKEND_ORIGIN=http://127.0.0.1:5000

# Neo4j knowledge graph (optional; set when using Neo4j mode)
KG_NEO4J_URI=
KG_NEO4J_USERNAME=
KG_NEO4J_PASSWORD=
KG_NEO4J_DATABASE=neo4j

# Frontend ASR activation tuning (optional)
NEXT_PUBLIC_SERVER_ASR_ACTIVE_COOLDOWN_MS=350
NEXT_PUBLIC_CLIENT_ASR_TRANSCRIPT_STALL_END_MS=2600
NEXT_PUBLIC_ASR_INPUT_CALIBRATION_MS=0
NEXT_PUBLIC_ASR_PREBUFFER_TARGET_MS=2200
NEXT_PUBLIC_ASR_NOISE_FLOOR_MIN=0.001
NEXT_PUBLIC_ASR_NOISE_FLOOR_MAX=0.03
NEXT_PUBLIC_ASR_ACTIVATION_MIN=0.002
NEXT_PUBLIC_ASR_ACTIVATION_MAX=0.035
NEXT_PUBLIC_ASR_ACTIVATION_MULTIPLIER=1.7
NEXT_PUBLIC_ASR_STRONG_SPEECH_MULTIPLIER=1.08
NEXT_PUBLIC_ASR_HOLD_MIN=0.006
NEXT_PUBLIC_ASR_HOLD_MAX=0.028
NEXT_PUBLIC_ASR_HOLD_MULTIPLIER=2.6
NEXT_PUBLIC_ASR_FAST_START_WINDOW_MS=8000
NEXT_PUBLIC_ASR_FAST_START_ACTIVATION_MIN=0.0015
NEXT_PUBLIC_ASR_FAST_START_ACTIVATION_MULTIPLIER=1.15
NEXT_PUBLIC_ASR_FAST_START_STRONG_MULTIPLIER=1.05
NEXT_PUBLIC_ASR_ECHO_CANCELLATION=true
NEXT_PUBLIC_ASR_NOISE_SUPPRESSION=true
NEXT_PUBLIC_ASR_AUTO_GAIN_CONTROL=true
