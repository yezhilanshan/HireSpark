# Public access
PUBLIC_SITE_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_BACKEND_URL=http://YOUR_SERVER_IP:5000
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:5000

# Frontend auth
AUTH_LOGIN_EMAIL=admin@panelmind.cn
AUTH_LOGIN_PASSWORD=PanelMind123
AUTH_LOGIN_NAME=PanelMind 管理员

# Backend CORS / Socket.IO
SOCKETIO_CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# Qwen / DashScope
DASHSCOPE_API_KEY=
BAILIAN_API_KEY=

# Assistant
ASSISTANT_ENABLED=true
ASSISTANT_PROVIDER=qwen
ASSISTANT_MODEL=qwen-plus

# TTS
TTS_ENABLED=false
TTS_MODE=remote
TTS_SERVICE_URL=http://127.0.0.1:5001
TTS_TIMEOUT=45

# Optional
OPENROUTER_API_KEY=
