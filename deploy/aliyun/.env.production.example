# Public access
PUBLIC_SITE_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_BACKEND_URL=http://YOUR_SERVER_IP:5000
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:5000

# Frontend auth
AUTH_LOGIN_EMAIL=admin@hirespark.cn
AUTH_LOGIN_PASSWORD=HireSpark123
AUTH_LOGIN_NAME=HireSpark 管理员

# Backend CORS / Socket.IO
SOCKETIO_CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# Qwen / DashScope
DASHSCOPE_API_KEY=
BAILIAN_API_KEY=

# Assistant
ASSISTANT_ENABLED=true
ASSISTANT_PROVIDER=qwen
ASSISTANT_MODEL=qwen-plus
ASSISTANT_ASYNC_ENABLED=true
ASSISTANT_TASK_MAX_WORKERS=2
ASSISTANT_TASK_RETENTION_SECONDS=900
ASSISTANT_FAST_ACK_TEXT=已接收，正在分析你的问题...

# TTS
TTS_ENABLED=false
TTS_MODE=remote
TTS_SERVICE_URL=http://127.0.0.1:5001
TTS_TIMEOUT=45
TTS_PROVIDER=cosyvoice
TTS_PROVIDER_ORDER=cosyvoice,edgetts
TTS_PROVIDER_STRICT=false
TTS_COSYVOICE_MODEL=cosyvoice-v3-flash
TTS_COSYVOICE_VOICE=Chinese_dramatic_storyteller_vv1
# Optional aliases
# TTS_MODEL=cosyvoice-v3-flash
# TTS_VOICE=Chinese_dramatic_storyteller_vv1

# Optional
OPENROUTER_API_KEY=
